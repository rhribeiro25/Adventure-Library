@startuml
actor user as "Angular App"

box "API Layer" #LightBlue
participant "BookController" as controller <<(C,#ADD1B2)>>
end box

box "Application Layer" #LightGreen
participant "BookUseCase" as usecase <<(C,#ADD1B2)>>
end box

box "Persistence Layer" #LightCoral
participant "CategoryRepository" as categoryRepo <<(I,#ADD1B2)>>
participant "BookRepository" as bookRepo <<(I,#ADD1B2)>>
end box

database "PostgreSQL" as db #MediumBlue

note right user
DELETE /api/v1/books/{bookId}/categories/{categoryId}
end note
user -> controller
controller -> usecase : removeCategory(bookId, categoryId)

usecase -> bookRepo : findBook(bookId)
bookRepo -> db : SELECT book
db --> bookRepo : BookEntity
bookRepo -> usecase : Book

usecase -> usecase : removeCategory(book, categoryId)

usecase -> bookRepo : update(book)
bookRepo -> db : UPDATE book_category
db --> bookRepo : saved
bookRepo -> usecase : Book

usecase --> controller : BookDetailsResponse
controller --> user : 204 No Content
@enduml