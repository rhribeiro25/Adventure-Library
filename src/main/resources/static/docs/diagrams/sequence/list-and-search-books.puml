@startuml
actor user as "Angular App"

box "API Layer" #LightBlue
participant "BookController" as controller <<(C,#ADD1B2)>>
end box

box "Application Layer" #LightGreen
participant "BookUseCase" as usecase <<(C,#ADD1B2)>>
end box

box "Persistence Layer" #LightCoral
participant "BookRepository" as repository <<(I,#ADD1B2)>>
end box

database "PostgreSQL" as db #MediumBlue

note right user
GET /api/v1/books?query=&author=&difficulty=&category=&page=0&size=10&sort=title,asc
end note
user -> controller

controller -> usecase : searchBooks(criteria)
usecase -> repository : findBooks(criteria)
repository -> db : SELECT books with filters
db --> repository : Page<BookEntity>
repository --> usecase : Page<Book>
usecase --> controller : Page<BookSummaryResponse>
controller --> user : 200 OK
@enduml