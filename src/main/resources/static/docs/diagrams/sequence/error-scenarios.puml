@startuml
skinparam sequenceParticipantBorderColor Black
skinparam sequenceParticipantBackgroundColor #FFFFFF

actor user as "Angular App"

box "API Layer" #LightBlue
participant "Controller" as controller <<(C,#ADD1B2)>>
participant "GlobalExceptionsHandler" as handler <<(C,#ADD1B2)>>
end box

box "Application Layer" #LightGreen
participant "UseCase" as usecase <<(C,#ADD1B2)>>
participant "BookValidator" as validator <<(C,#ADD1B2)>>
end box

box "Persistence Layer" #LightCoral
participant "Repository" as repository <<(C,#ADD1B2)>>
end box

database "PostgreSQL" as db #MediumBlue

group Book Not Found
    user -> controller : GET /api/v1/books/{bookId}
    controller -> usecase : getBookDetails(bookId)
    usecase -> repository : findById(bookId)
    repository -> db : SELECT book
    db --> repository : empty
    repository --> usecase : Optional.empty
    usecase --> controller : throws BusinessException
    controller -> handler : handleBusinessException()
    handler --> user : 404 Not Found
end

group Invalid Book
    user -> controller : POST /api/v1/books
    controller -> usecase : addBook(request)
    usecase -> validator : validate(book)
    validator --> usecase : throws BusinessException
    usecase --> controller : throws BusinessException
    controller -> handler : handleBusinessException()
    handler --> user : 400 Bad Request
end

group Invalid Choice
    user -> controller : POST /api/v1/games/{gameId}/choices
    controller -> usecase : chooseOption(gameId, optionId)
    usecase --> controller : throws BusinessException
    controller -> handler : handleBusinessException()
    handler --> user : 400 Bad Request
end

group Unexpected Failure
    user -> controller : Any request
    controller -> usecase : execute()
    usecase --> controller : throws RuntimeException
    controller -> handler : handleInternalServerError()
    handler --> user : 500 Internal Server Error
end
@enduml